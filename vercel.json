{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin.html",
      "use": "@vercel/static"
    },
    {
      "src": "mathlive.min.js",
      "use": "@vercel/static"
    },
    {
      "src": "api/verify.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/users",
      "dest": "/api/users.js"
    },
    {
      "src": "/api/questions",
      "dest": "/api/questions.js"
    },
    {
      "src": "/api/nodes",
      "dest": "/api/nodes.js"
    },
    {
      "src": "/api/logs",
      "dest": "/api/logs.js"
    },
    {
      "src": "/api/setup",
      "dest": "/api/setup.js"
    },
    {
      "src": "/api/seed",
      "dest": "/api/seed.js"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/mathlive.min.js",
      "dest": "/mathlive.min.js"
    },
    {
      "src": "/api/verify",
      "dest": "/api/verify.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/api/leaderboard",
      "dest": "/api/leaderboard.js"
    }
  ]
}