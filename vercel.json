{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "admin.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth", "dest": "/api/auth.js" },
    { "src": "/api/users", "dest": "/api/users.js" },
    { "src": "/api/questions", "dest": "/api/questions.js" },
    { "src": "/api/nodes", "dest": "/api/nodes.js" },
    { "src": "/api/logs", "dest": "/api/logs.js" },
    { "src": "/api/setup", "dest": "/api/setup.js" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
